    currentRule = getRule("Start2Block6");
    currentSet = getSet("\n");
    
    currentAlt = new Alternative();
    
    addTest(3, "\n", "", 1, 999999, "defaultSKIP");
    
    
    addTest(1, "\n", "", 1, 1, "defaultSKIP");
    
    currentRule.alternatives += currentAlt;
}
