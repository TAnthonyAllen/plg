/*******************************************************************************
    PLG class definition
*******************************************************************************/
class PLG
{
PLGset      alternateSet,
            characterSet,
            commandSet,
            commentSet,
            elementSet,
            excludeSet,
            nameSet,
            numberSet,
            singleQuote;
BaseHash    plgRuleTable,
            plgSetTable;
Buffer      output,
            buffer,
            headerBuffer,
            includeBuffer,
            parseBuffer;
Stak        ruleStack,
            testStack;
String      parentParser;
PLGitem     tail,
            ruleActionName;
int         alternateFlag,
            blockCount,
            optionCount,
            regexCount,
            testFlag;
boolean     hasActions,
            hasConditions,
            hasKeys,
            hasSets,
            hasVariables;
PLGparse    parser;

/*******************************************************************************
	PLG constructors
*******************************************************************************/
PLG()
{
    init();
}

PLG(String input)
{
    init();
    setInput(input);
}

void init()
{
    parser          = new;
    output          = new("plgOutput",10000);
    buffer          = new("plgBuffer");
    headerBuffer    = new("plgHeader");
    includeBuffer   = new("plgInclude");
    parseBuffer     = new("plgParse");
    parserName      = "PLG";
    ruleStack       = new;
    testStack       = new;
    parser          = new;
}

/*******************************************************************************
	Method to test the parse
*******************************************************************************/
void run()
{
    setRules();
    initialize();
    setInput(",678");
PLGitem result = parse("Max");
    if result
        cout "matched " result.itemLength " chars: " result.toString():;
    else cout "no match":;
}

/*******************************************************************************
	process — load a grammar file, run it through the parser starting at the
	"Start" rule, then emit a .twk file (foo.g -> foo.twk) containing the
	generated setRules().
*******************************************************************************/
void process(String filename)
{
String  content;
PLGitem result;
Buffer  twkOut;
String  outFile;
String  dot;
    setRules();
    initialize();
    content = getStringFromFile(filename);
    if !content
        {
        cerr "process: could not load " filename:;
        return;
        }
    setInput(content);
    result = parse("Start");
    if result
        cout "parsed " result.itemLength " chars from " filename:;
    else cout "parse failed on " filename:;

    // Build output path: foo.g -> foo.twk
    outFile = malloc(strlen(filename) + 8);
    strcpy(outFile, filename);
    dot = strrchr(outFile, '.');
    if dot
        { *dot = '\0'; }
    strcat(outFile, ".twk");

    twkOut = new("twk-output", 50000);
    parser.generateRules(twkOut);
    twkOut.setFile(outFile);
    twkOut.flush();
    cout "wrote " outFile:;
    free(outFile);
}

/*******************************************************************************
	setRules copied over from plg.twk
*******************************************************************************/
void setRules()
{
use parser
Alternative alt;
Element     elem;
    setSkip();
alternateSet = getSet("alternateSet","#([~'a-zA-Z");
characterSet = getSet("characterSet","[a-zA-Z");
commandSet   = getSet("commandSet","derst");
commentSet   = getSet("commentSet","derst/");
elementSet   = getSet("elementSet","[(a-zA-Z~'");
excludeSet   = getSet("excludeSet","A-Za-z:.|");
nameSet      = getSet("nameSet","a-zA-Z");
numberSet    = getSet("numberSet","0-9");
singleQuote  = getSet("singleQuote","'");

    currentRule = getRule("Integer");
