include /Users/anthony/Dropbox/data/InProcess/Include/globals
include /Users/anthony/Dropbox/data/InProcess/Include/frame
include PLGrevision

/*******************************************************************************
	Class that embodies the Alternative rule in plg
*******************************************************************************/
class Alternative
{
DoubleLinkList  elements;
PLGset          guardSet;

int match(PLGparse state, PLGitem *out);

/*******************************************************************************
	Alternative constructor
*******************************************************************************/
Alternative()
{
    elements = new;
}

/*******************************************************************************
	Emit an alternative in addTest-compatible form: assign currentAlt, let
	each element emit its own addTest()/setX() lines, then attach currentAlt
	to currentRule. Matches the hand-written setRules() convention so
	generated output can be pasted in directly.
*******************************************************************************/
void generate(Buffer output)
{
Element elem;
    print(output) "currentAlt = new Alternative();":;
    elements.resetIterator();
    while elem = elements.next()
        elem.generate(output);
    print "currentRule.alternatives += currentAlt;":;
}

int match(PLGparse state, PLGitem &out)
{
PLGitem     collected = new;
DoubleLink  link = null;
DoubleLink  dlink = null;
Element     elem;
int         result = true;
int         elemIdx = 0;
String      altStart = state.cursor;
cout "Alternative match elements: " elements.length():;
    collected.start = state.cursor;
    for link = elements.first {
        elem = link.value;
        elemIdx++;
        // Verbose per-element trace: index, kind, target, cursor before.
        // For kRuleRef/kLit we print the ref-name or literal so the trace
        // tells us which sub-match was attempted at which offset.
        // NOTE: kRuleRef etc. are TEST macros not values (CLAUDE.md TAWK
        // quirks) — use numeric kind values for assignment/comparison.
        {
        String      what = "?";
        if elem.kind == 6 && elem.ruleRef   what = elem.ruleRef.name;
        else if elem.kind == 1 && elem.litText  what = elem.litText;
        cout "    elem[" elemIdx "] kind=" elem.kind " target='" what "' min=" elem.minimum " label='" elem.label "' cursor-offset=" (state.cursor - state.buffer.start):;
        }
        String beforeCursor = state.cursor;
        PLGitem item = elem.match(state);
        cout "    elem[" elemIdx "] result=" (item ? "MATCH" : "null") " cursor-now=" (state.cursor - state.buffer.start) " consumed=" (state.cursor - beforeCursor):;
        if !item
            {
            // Banged elements (`!`, min=-1) ARE required even though their
            // minimum looks optional — null from a banged element means
            // the negative lookahead saw what it was excluding, so the
            // alternative must fail.
            if elem.minimum > 0 || elem.banged
                {
                result = false;
                break;
                }
            // optional element didn't match — keep going, cursor unchanged
            }
        else
            {
            if item.label
                {
                if !collected.children  collected.children = new;
                collected.children[item.label] = item;
                }
            // Cascade deferred entries up — each sub-match may have
            // accumulated rule defers that need to fire after the
            // enclosing rule completes.
            if item.deferred
                {
                if !collected.deferred  collected.deferred = new DoubleLinkList();
                for dlink = item.deferred.first
                    collected.deferred += dlink.value;
                }
            }
        }
    if result {
        collected.length = state.cursor - collected.start;
        out = collected; }
    return result;
}
}
