include /Users/anthony/Dropbox/data/InProcess/Include/globals
include /Users/anthony/Dropbox/data/InProcess/Include/frame
include /Users/anthony/Dropbox/data/InProcess/Include/PLGrevision

/*******************************************************************************
	Class that embodies the Alternative rule in plg
*******************************************************************************/
class Alternative
{
DoubleLinkList  elements;
PLGset          guardSet;
// Per-alternative action. An action belongs to one alternative (option) of a
// rule, not the whole rule. immediateAction/deferAction hold the body (set by
// generateRules from the .act-attached numbered-rule shells); actionName is the
// emitted method's base name (Rule, Rule2, …). immediate/defer are the wired
// function pointers fired by PLGrule::match when this alternative matches.
PLGitem         immediateAction,
                deferAction;
String          actionName;
int             &immediate(PLGparse state, PLGitem i);
void            &defer(PLGparse state, PLGitem i);

int match(PLGparse state, PLGitem *out);

/*******************************************************************************
	Alternative constructor
*******************************************************************************/
Alternative()
{
    elements = new;
}

/*******************************************************************************
	Emit an alternative in addTest-compatible form: assign currentAlt, let
	each element emit its own addTest()/setX() lines, then attach currentAlt
	to currentRule. Matches the hand-written setRules() convention so
	generated output can be pasted in directly.
*******************************************************************************/
void generate(String parserName, Buffer output)
{
Element elem;
    print(output) "currentAlt = new Alternative();":;
    elements.resetIterator();
    while elem = elements.next()
        elem.generate(output);
    if immediateAction
        print "currentAlt.immediate = " actionName parserName "Now;":;
    if deferAction
        print "currentAlt.defer = " actionName parserName "Act;":;
    print "currentRule.alternatives += currentAlt;":;
}

/*****************************************************************************
    Emit the capture-variable declarations for this alternative's action:
    one `PLGitem <label> = iTEM.children["<label>"];` per distinct labelled
    element of THIS alternative (so each option's action sees exactly its own
    captures — no cross-alternative bleed).
*****************************************************************************/
void writeCaptures(Buffer output)
{
Element     elem;
DoubleLink  elemLink;
BaseHash    seen = new;
    if !elements return;
    for elemLink = elements.first
        {
        elem = elemLink.value;
        if elem.label && !seen[elem.label]
            {
            seen[elem.label] = (void*)1;
            print(output) "PLGitem " elem.label " = iTEM.children[\"" elem.label "\"];":;
            }
        }
}

/*****************************************************************************
    Emit this alternative's action method body (inside the generated parser
    class). Method name is <actionName><parserName>Now (immediate) or
    <actionName><parserName>Act (deferred), matching the wiring in generate()
    and the forward declarations in tok.ext's `external Tawk`.
*****************************************************************************/
void writeActions(String parserName, Buffer output)
{
    if immediateAction
        {
        print(output) :"int " actionName parserName "Now(PLGitem iTEM)\n{":;
        writeCaptures(output);
        print immediateAction.toString();
        print :"return true;\n}\n":;
        }
    if deferAction
        {
        print(output) :"void " actionName parserName "Act(PLGitem iTEM)\n{":;
        writeCaptures(output);
        print deferAction.toString();
        print :"}\n":;
        }
}

int match(PLGparse state, PLGitem &out)
{
PLGitem     collected = new;
DoubleLink  link = null;
DoubleLink  dlink = null;
Element     elem;
int         result = true;
int         elemIdx = 0;
    collected.start = cursor;
    for link = elements.first {
        String  what = "?";
        elem = link.value;
        elemIdx++;
        // Verbose per-element trace: index, kind, target, cursor before.
        // For kRuleRef/kLit we print the ref-name or literal so the trace
        // tells us which sub-match was attempted at which offset.
        // NOTE: kRuleRef etc. are TEST macros not values (CLAUDE.md TAWK
        // quirks) — use numeric kind values for assignment/comparison.
        if elem.kind == 6 && elem.ruleRef   what = elem.ruleRef.name;
        else if elem.kind == 1 && elem.litText  what = elem.litText;
        PLGitem item = elem.match(state);
        if !item
            {
            // Banged elements (`!`, min=-1) ARE required even though their
            // minimum looks optional — null from a banged element means
            // the negative lookahead saw what it was excluding, so the
            // alternative must fail.
            if elem.minimum > 0 || elem.banged
                {
                result = false;
elementFail:
                break;
                }
            // optional element didn't match — keep going, cursor unchanged
            }
        else
            {
elementSuccess:
            if item.label
                {
                if !collected.children  collected.children = new;
                collected.children[item.label] = item;
                }
            // Cascade deferred entries up — each sub-match may have
            // accumulated rule defers that need to fire after the
            // enclosing rule completes.
            if item.deferred
                {
                if !collected.deferred  collected.deferred = new DoubleLinkList();
                for dlink = item.deferred.first
                    collected.deferred += dlink.value;
                }
            }
        }
    if result {
        collected.length = cursor - collected.start;
        out = collected; }
    return result;
}
}
