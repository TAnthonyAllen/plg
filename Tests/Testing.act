Test!
.
PLGitem nameItem = iTEM.children["name"];;
String  itemName;
PLGset  newSet;
    if !nameItem return false;
    itemName = nameItem.toString();
    newSet = new PLGset(itemName);
    newSet.name = itemName;
    setTable[itemName] = (void*)newSet;
    return true;
;
