# Dropbox keeps re-creating this Xcode shell after we deleted it; keep it out
/NewPLG/

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*

# Editor swap / backup files
*.swp
*.swo
*~
.*.swp
.*.swo

# Xcode — user-specific state
**/xcuserdata/
**/*.xcuserstate
**/project.xcworkspace/xcuserdata/

